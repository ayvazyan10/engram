{
  "name": "engram",
  "private": true,
  "version": "0.1.0",
  "description": "Universal AI Brain — persistent memory and cognition layer for any AI model",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "e2e": "turbo run e2e",
    "db:generate": "pnpm --filter @engram/core drizzle-kit generate",
    "db:migrate": "pnpm --filter @engram/core drizzle-kit migrate",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@engram/eslint-config": "workspace:*",
    "@engram/tsconfig": "workspace:*",
    "@types/node": "22",
    "prettier": "3.5.2",
    "turbo": "2.3.3",
    "typescript": "5.7.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
