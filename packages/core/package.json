{
  "name": "@engram/core",
  "version": "0.1.0",
  "description": "The Brain — memory engine, embeddings, graph, and retrieval",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "clean": "rm -rf dist *.tsbuildinfo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "better-sqlite3": "^11.9.1",
    "drizzle-orm": "^0.40.0",
    "lz4js": "^0.2.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@engram/tsconfig": "workspace:*",
    "@types/better-sqlite3": "^7.6.12",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.30.0",
    "typescript": "5.7.3",
    "vitest": "^3.1.1"
  }
}
